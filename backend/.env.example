# Copy to .env and fill in (never commit .env)
# Trip planner uses Anthropic — required for POST /api/plan-trip

ANTHROPIC_API_KEY=

# Postgres — used by SQLModel/Alembic
DATABASE_URL=postgresql+psycopg://drift:drift@localhost:5432/drift

# Optional — for future RIDB / Supabase server integrations
RIDB_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
